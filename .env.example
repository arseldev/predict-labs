# Salin file ini ke .env dan isi dengan nilai asli
# JANGAN commit file .env ke Git!

# Binance Live API (untuk Phase 7 saja)
BINANCE_API_KEY=your_live_api_key_here
BINANCE_API_SECRET=your_live_api_secret_here

# Binance Testnet API (untuk Phase 6 — Paper Trading)
# Daftar di: https://testnet.binance.vision/
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# Telegram Bot (untuk notifikasi prediksi)
# Buat bot via @BotFather di Telegram, lalu cari chat_id via @userinfobot
BOT_TOKEN=your_telegram_bot_token_here
BOT_TARGET_ID=your_telegram_chat_id_here
